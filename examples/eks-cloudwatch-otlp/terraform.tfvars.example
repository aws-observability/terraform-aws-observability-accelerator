# Copy to terraform.tfvars or use -var flags / install.sh

aws_region     = "us-west-2"
eks_cluster_id = "my-cluster"

# Optional: override the CloudWatch OTLP metrics endpoint (defaults to regional)
# cloudwatch_metrics_endpoint = "https://monitoring.us-west-2.amazonaws.com/v1/metrics"

# Optional: override log group/stream
# cloudwatch_log_group  = "/eks/otel-collector"
# cloudwatch_log_stream = "otel-logs"

# Leave these empty — install.sh populates them automatically on the second apply.
# grafana_endpoint = ""
# grafana_api_key  = ""
